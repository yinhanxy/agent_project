# ==============================================
# LLM 大模型配置
# ==============================================
# LLM类型：ALIYUN(阿里云百炼) | OLLAMA(本地模型)
LLM_TYPE=ALIYUN

# ==============================================
# Ollama 配置（仅 LLM_TYPE=OLLAMA 时生效）
# ==============================================
# Ollama 服务地址（本地运行Ollama时，默认为该地址）
OLLAMA_BASE_URL=http://localhost:11434
# Ollama 聊天模型（需提前 ollama pull 下载）
OLLAMA_MODEL_NAME=qwen3.5:0.8b

# ==============================================
# 阿里云百炼配置（仅 LLM_TYPE=ALIYUN 时生效），可能产生费用，注意控制用量
# ==============================================
# 阿里云 API Key（格式：sk-xxxx）
# 申请地址：https://dashscope.console.aliyun.com/
ALIYUN_ACCESS_KEY_SECRET=
# 阿里云 API 地址
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 阿里云聊天模型名称
CHAT_MODEL_NAME=qwen3-max

# ==============================================
# 向量嵌入模型配置
# ==============================================
# 嵌入模型类型：OLLAMA | ALIYUN
EMBED_MODEL_TYPE=OLLAMA
# Ollama 嵌入模型（需提前下载），当EMBED_MODEL_TYPE=OLLAMA时使用
TEXT_EMBEDDING_MODEL_NAME=qwen3-embedding:0.6b
# 阿里云嵌入模型（当EMBED_MODEL_TYPE=ALIYUN时使用），需确保阿里云百炼平台有该模型且账户余额充足
ALIYUN_EMBED_MODEL_NAME=qwen3-vl-embedding

# ==============================================
# 数据库配置
# ==============================================
# MySQL 配置
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=chat_history

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==============================================
# 向量数据库后端选择
# ==============================================
# chroma（嵌入式，默认）| milvus（独立服务，需先启动 docker-compose.milvus.yml）
VECTOR_STORE_BACKEND=chroma

# Milvus 连接（仅 VECTOR_STORE_BACKEND=milvus 时生效）
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Django API 地址，用户服务地址，用于调用用户服务的API
DJANGO_API_URL=http://127.0.0.1:8001

# LangSmith 调试追踪
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=my-fastapi-langchain-project

# ==============================================
# 重排序模型配置
# ==============================================
# 重排序模型本地路径（自动从魔搭社区下载）
RERANKER_MODEL_PATH=D:\Hugging_Face\models\Qwen3-Reranker-0.6B

# ==============================================
# RAG 生成链路配置
# ==============================================
# agent：RAG 只返回检索片段和结构化 citations，由 Agent 生成最终回答（推荐，减少重复 LLM 调用）
# rag：RAG 工具内部生成摘要，保留旧行为
RAG_GENERATION_MODE=agent

# ==============================================
# JWT 身份验证配置
# ==============================================
SECRET_KEY=
ALGORITHM=HS256
